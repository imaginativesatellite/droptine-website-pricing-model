# Copy to .env for local dev. In production, set these in Railway → Variables.
# NEVER commit real secrets — .env is gitignored.

# Postgres (Railway provides this automatically when you add a Postgres plugin)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE"

# Auth.js / NextAuth — generate with:  openssl rand -base64 32
AUTH_SECRET="replace-me"
# Your deployed URL (e.g. https://droptine.up.railway.app). Localhost for dev.
NEXTAUTH_URL="http://localhost:3000"

# Anthropic (proposal prose only — never pricing)
# AI is OFF unless ENABLE_AI is exactly "true". Leave unset/false to skip it.
ENABLE_AI="false"
# Separate switch for the admin AI price-recommendation button on custom quotes.
ENABLE_AI_PRICING="false"
ANTHROPIC_API_KEY="sk-ant-..."
ANTHROPIC_MODEL="claude-opus-4-8"

# Resend (transactional email)
RESEND_API_KEY="re_..."
# Verified sending identity on your Resend domain
EMAIL_FROM="Luna Creative <proposals@notifications.luna-creative.com>"
# Comma-separated admin recipients (every quote + custom requests)
ADMIN_EMAILS="david@luna-creative.com"

# DocuSeal (e-signature) — set DOCUSEAL_API_KEY to enable the "Send for
# signature" button on approved/proposal quotes. Leave unset to skip it.
# Point DOCUSEAL_API_URL at your self-hosted instance's /api endpoint
# (e.g. https://docuseal.up.railway.app/api), or leave it for DocuSeal's cloud.
DOCUSEAL_API_KEY=""
DOCUSEAL_API_URL="https://api.docuseal.com"
# Optional: shared secret your DocuSeal instance sends back on webhook
# requests (as an X-Docuseal-Webhook-Secret header) to /api/webhooks/docuseal.
DOCUSEAL_WEBHOOK_SECRET=""

# Seed credentials for the first admin account (used by prisma/seed.ts)
SEED_ADMIN_EMAIL="david@luna-creative.com"
SEED_ADMIN_NAME="David"
SEED_ADMIN_PASSWORD="change-me-after-first-login"
