# Copy to .env for local dev. In production, set these in Railway → Variables.
# NEVER commit real secrets - .env is gitignored.

# Postgres (Railway provides this automatically when you add a Postgres plugin)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE"

# Auth.js / NextAuth - generate with:  openssl rand -base64 32
AUTH_SECRET="replace-me"
# Your deployed URL (e.g. https://droptine.up.railway.app). Localhost for dev.
NEXTAUTH_URL="http://localhost:3000"

# Anthropic (proposal prose only - never pricing)
# AI is OFF unless ENABLE_AI is exactly "true". Leave unset/false to skip it.
ENABLE_AI="false"
# Separate switch for the admin AI price-recommendation button on custom quotes.
ENABLE_AI_PRICING="false"
ANTHROPIC_API_KEY="sk-ant-..."
ANTHROPIC_MODEL="claude-opus-4-8"

# Resend (transactional email)
RESEND_API_KEY="re_..."
# Verified sending identity on your Resend domain
EMAIL_FROM="Luna Creative <proposals@notifications.luna-creative.com>"
# Comma-separated admin recipients (every quote + custom requests)
ADMIN_EMAILS="david@luna-creative.com"

# Documenso (self-hosted e-signature, github.com/documenso/documenso, AGPL) -
# set DOCUMENSO_API_KEY + DOCUMENSO_COMPANY_EMAIL to enable the "Send for
# signature" flow on approved/proposal quotes. Leave unset to skip it.
# Point DOCUMENSO_API_URL at your self-hosted instance's base URL with no
# /api suffix (e.g. a Railway deployment), or leave it for Documenso's
# hosted cloud (https://app.documenso.com).
DOCUMENSO_API_KEY=""
DOCUMENSO_API_URL="https://app.documenso.com"
# The shared "company" identity any logged-in admin signs as - see
# src/lib/documenso.ts for why this is one shared recipient instead of each
# admin's own account.
DOCUMENSO_COMPANY_EMAIL=""
DOCUMENSO_COMPANY_NAME="Luna Creative LLC"
# Optional: shared secret your Documenso instance sends back on webhook
# requests (as an X-Documenso-Secret header) to /api/webhooks/documenso.
DOCUMENSO_WEBHOOK_SECRET=""

# Seed credentials for the first admin account (used by prisma/seed.ts)
SEED_ADMIN_EMAIL="david@luna-creative.com"
SEED_ADMIN_NAME="David"
SEED_ADMIN_PASSWORD="change-me-after-first-login"
