// Droptine pricing model - database schema
// Postgres on Railway. `prisma db push` runs automatically on deploy.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  MEMBER
  ADMIN
}

enum QuoteStatus {
  PROPOSAL        // auto-priced; PDF + code page generated; emailed to the member
  CUSTOM_PENDING  // "additional functionality" / complex - awaiting admin approval
  APPROVED        // admin set a price and approved a custom quote
}

// Where a quote came from. LUNA_REQUEST = the normal flow (Droptine requesting a
// quote from Luna Creative). CLIENT = generated in the client-facing Presentation
// Mode portal and shown straight to an end client (Luna price + Droptine markup).
enum QuoteOrigin {
  LUNA_REQUEST
  CLIENT
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  phone        String?
  passwordHash String
  role         Role     @default(MEMBER)
  createdAt    DateTime @default(now())

  // Client-facing Presentation Mode access. Off for everyone by default; turned
  // on for the pilot member (and all admins are allowed regardless of this flag -
  // see canUseClientPortal in src/lib/portal.ts). Eventually flipped on for all.
  clientPortalEnabled Boolean @default(false)

  // Initial visibility for this user's new quotes (admins set it per member on
  // the Users tab; the creator can still flip it per quote). true = start private.
  quotesDefaultPrivate Boolean @default(false)

  // Per-member markup applied on top of Luna Creative's deterministic price when
  // a quote is generated in the client portal. The Luna engine (src/lib/pricing.ts)
  // never sees these - markup is a layer added afterward, and only for CLIENT quotes.
  markupWebsite          Int     @default(5000) // website build markup
  markupWebsiteIsPercent Boolean @default(false) // website markup is a % of the build price (else a flat $)
  markupMonthly          Int     @default(50)   // added to the monthly price (flat $ only)
  markupIncrement        Int     @default(500)  // $ added per tap of the price arrows (flat $ only)

  // platform terms acceptance (MEMBER accounts only) - snapshot of the exact
  // text agreed to, so the Account page stays accurate even if wording changes later
  termsAcceptedAt   DateTime?
  termsAcceptedText String?   @db.Text

  clients        Client[]    @relation("ClientOwner")
  quotes         Quote[]     @relation("CreatedBy")
  approvedQuotes Quote[]     @relation("ApprovedBy")
  signedQuotes   Quote[]     @relation("CompanySignedBy")
  quoteEdits     QuoteEdit[]
}

// A client/business that quotes are grouped under (the dashboard is organized
// by client). Owned by the Droptine member who created it.
model Client {
  id        String   @id @default(cuid())
  name      String
  // Contact person + details captured in the client portal (optional). The
  // business goes in `name`; this is the individual to follow up with.
  contactName String?
  email     String?
  phone     String?
  ownerId   String
  owner     User     @relation("ClientOwner", fields: [ownerId], references: [id])
  quotes    Quote[]
  createdAt DateTime @default(now())

  @@index([ownerId])
}

model Quote {
  id     String      @id @default(cuid())
  // short, human-shareable access code for the private proposal page
  code   String      @unique
  // long, hard-to-guess code used in the public proposal URL
  publicCode String   @unique
  status QuoteStatus @default(PROPOSAL)

  // Which dashboard tab this quote lives under. CLIENT quotes are generated in
  // Presentation Mode; "Request Quote from Luna Creative" flips one to
  // LUNA_REQUEST and stamps convertedToLunaAt (drives the "from client" marker).
  origin            QuoteOrigin @default(LUNA_REQUEST)
  convertedToLunaAt DateTime?
  // Snapshot of how a CLIENT quote's price was composed, for transparency:
  // { lunaBase, markup, markupIsPercent, increments, incrementAmount, monthlyMarkup }.
  // The actual numbers live in computedTotal / monthly / discount as usual.
  clientPricing     Json?

  // who generated it (proposal email always goes to this user)
  createdById String
  createdBy   User   @relation("CreatedBy", fields: [createdById], references: [id])

  clientId String
  client   Client @relation(fields: [clientId], references: [id])

  proposalName String

  // structured questionnaire answers (see src/lib/questionnaire.ts)
  answers Json

  // pricing - computed deterministically by the engine; never by the LLM
  computedTotal Int      // one-time build price, USD whole dollars
  overrideTotal Int?     // admin manual override; when set, replaces computedTotal
  discount      Int      @default(0) // admin discount, shown as a line item
  monthly       Int      @default(169)
  // manual turnaround override (business days); falls back to price-based
  leadDaysOverride Int?
  // accelerated turnaround (business days) the client requested via the rush
  // option; set only when a rush fee was applied. Drives the proposal's
  // turnaround number and the strike-through of the original estimate.
  rushDays      Int?
  // up to 3 single-line admin disclaimers: [{ text, placement }], placement
  // is "development" | "monthly"
  disclaimers   Json?
  // why the price was raised/lowered/overridden - internal-only, never shown
  // to the member; freeform notes an admin can later feed back into pricing
  priceReason   String?  @db.Text
  notes         String?  @db.Text
  scopeSummary  String?  @db.Text // LLM-drafted prose (price stays deterministic)

  // price snapshot at creation time, so historical quotes don't shift if the
  // pricing engine changes later: [{ label, amount }]
  lineItems     Json?

  // what we actually charged the client (for quoted-vs-actual analysis)
  actualCharged Int?

  // proposal email delivery tracking
  emailStatus   String?  // SENT | FAILED | SKIPPED
  emailError    String?  @db.Text

  // why a quote needs a custom follow-up (CUSTOM_PENDING)
  customReasons String[]

  // visibility: private to the creator (and admins) unless shared with everyone
  shared        Boolean  @default(false)

  // e-signature (Documenso) tracking - two parties sign sequentially: the
  // client, then any admin signing as the shared "Luna Creative" identity.
  // Updated by the Documenso webhook as each party views/signs/declines.
  signatureStatus      String?   // SENT | PARTIALLY_SIGNED | SIGNED | DECLINED
  signatureEnvelopeId  String?   // Documenso envelope/document id, for webhook correlation
  signatureSentAt      DateTime?
  clientSigningToken   String?   // Documenso recipient token - builds the client's signing iframe URL
  clientSignedAt       DateTime?
  companySigningToken  String?   // Documenso recipient token - builds the admin's signing iframe URL
  companySignedAt      DateTime?
  companySignedById    String?
  companySignedBy      User?     @relation("CompanySignedBy", fields: [companySignedById], references: [id])
  companySignedByName  String?   // denormalized snapshot, survives if the admin account is later removed
  signedDocumentUrl    String?   @db.Text
  signatureMeta        Json?     // raw Documenso payloads, kept for debugging

  // custom-quote approval
  approvedById String?
  approvedBy   User?     @relation("ApprovedBy", fields: [approvedById], references: [id])
  approvedAt   DateTime?

  createdAt DateTime    @default(now())
  // start of the 60-day validity window; reset when an admin reactivates
  validFrom DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  edits     QuoteEdit[]

  @@index([createdById])
  @@index([clientId])
  @@index([status])
  @@index([origin])
  @@index([signatureEnvelopeId])
  @@index([companySignedById])
}

// Audit trail: original auto price vs. manual edits, and who changed what.
model QuoteEdit {
  id         String   @id @default(cuid())
  quoteId    String
  quote      Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  editedById String
  editedBy   User     @relation(fields: [editedById], references: [id])
  field      String // e.g. "overrideTotal", "discount", "notes", "status"
  oldValue   String?  @db.Text
  newValue   String?  @db.Text
  createdAt  DateTime @default(now())

  @@index([quoteId])
}

// Admin-editable overrides for the transactional emails this app sends. Each
// row is keyed by a stable template key (see src/lib/email-templates.ts). The
// built-in defaults live in code; a row here only exists once an admin has
// customized that template's subject/body. Bodies are HTML with {{variable}}
// placeholders that are filled at send time.
model EmailTemplate {
  key       String   @id
  subject   String
  body      String   @db.Text
  // When false, this transactional email is suppressed entirely - the app
  // computes everything as normal but skips the actual send. Toggled from the
  // admin Emails tab. Defaults on, so an untouched template always sends.
  enabled   Boolean  @default(true)
  updatedAt DateTime @updatedAt
}

// Singleton row controlling the admin "demand adjustment" - a global
// percentage nudge on every new/recomputed quote total to account for
// being busy (raise prices) or slow (lower prices). Never exposed to members.
model PricingSettings {
  id            String   @id @default("singleton")
  adjustmentPct Int      @default(0)
  updatedAt     DateTime @updatedAt
}
